{
  "$schema": "https://opencode.ai/config.json",
  "tui": {
    "scroll_acceleration": { "enabled": true }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"]
    }
  },
  "default_agent": "plan",
  "lsp": true,
  "agent": {
    "plan": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "high"
    },
    "build": {
      "model": "openai/gpt-5.5"
    }
  },
  "plugin": ["opencode-claude-auth@latest"]
}
